# Configuration de l'application - Backend PHP
# =============================================

# Base de données
DB_HOST=localhost
DB_NAME=sanabel_dhahabia
DB_USER=root
DB_PASSWORD=

# Serveur PHP
PHP_HOST=localhost
PHP_PORT=8000

# Frontend Angular
ANGULAR_HOST=localhost
ANGULAR_PORT=4200

# Configuration d'authentification
JWT_SECRET=your_secret_key_here
JWT_EXPIRE=3600

# Email (optionnel)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your_email@gmail.com
MAIL_PASSWORD=your_password

# Environnement
ENVIRONMENT=development
# ENVIRONMENT=production

# Logs
LOG_LEVEL=debug
# LOG_LEVEL=error

# Chemins
UPLOADS_PATH=./uploads
TEMP_PATH=./temp
