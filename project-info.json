    "integrationStatus": "COMPLETE"
  },
  "frontend": {
    "framework": "Angular",
    "version": "17.0.0",
    "language": "TypeScript",
    "port": 4200,
    "startCommand": "npm start"
  },
  "backend": {
    "framework": "PHP",
    "version": "7.4+",
    "language": "PHP",
    "port": 8000,
    "startCommand": "cd backend && php -S localhost:8000",
    "database": {
      "type": "MySQL",
      "name": "sanabel_dhahabia",
      "version": "5.7+",
      "tables": 7,
      "script": "backend/database.sql"
    }
  },
  "api": {
    "baseUrl": "http://localhost:8000/backend/api",
    "endpoints": {
      "authentication": {
        "login": "POST /api/auth.php?action=login",
        "register": "POST /api/auth.php?action=register",
        "logout": "POST /api/auth.php?action=logout"
      },
      "products": {
        "list": "GET /api/products.php",
        "get": "GET /api/products.php?id={id}",
        "create": "POST /api/products.php",
        "update": "PUT /api/products.php?id={id}",
        "delete": "DELETE /api/products.php?id={id}"
      },
      "orders": {
        "list": "GET /api/orders.php?userId={userId}",
        "get": "GET /api/orders.php?id={id}",
        "create": "POST /api/orders.php",
        "updateStatus": "PUT /api/orders.php?id={id}&action=status"
      }
    }
  },
